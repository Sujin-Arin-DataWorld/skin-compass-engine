{
  "redirects": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "(?i).*\\.vercel\\.app"
        }
      ],
      "destination": "https://www.skinstrategylab.de/$1",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/skin-analysis",
      "has": [{ "type": "header", "key": "user-agent", "value": "(?i).*(bot|crawl|spider|facebookexternalhit|kakaotalk|whatsapp|slackbot|linkedinbot|discordbot|telegrambot|twitterbot|preview).*" }],
      "destination": "/api/og-skin-analysis"
    },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Pragma", "value": "no-cache" },
        { "key": "Expires", "value": "0" }
      ]
    },
    {
      "source": "/",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/assets/:path*.(js|css)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/assets/:path*.(png|jpg|jpeg|webp|svg|gif|mp4)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600, s-maxage=604800, stale-while-revalidate=86400" }
      ]
    }
  ]
}
